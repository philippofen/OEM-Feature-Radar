# -----------------------------------------------------------------------------
# OEM Feature Radar – Environment
# Kopiere nach `.env` (lokal) oder trage als Secrets in GitHub Actions ein.
# -----------------------------------------------------------------------------

# Supabase (Service-Role-Key, NICHT anon – Backend only)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# LLM-Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: Residential Proxy (erst scharf schalten, wenn OEMs blocken).
# Leer lassen, wenn nicht benötigt.
PROXY_URL=

# Storage-Bucket in Supabase (muss existieren, public=true für Screenshots)
STORAGE_BUCKET=oem-snapshots

# Logging / Verbosity
LOG_LEVEL=info
